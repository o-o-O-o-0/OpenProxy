{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "OpenProxy",
  "version": "0.1.0",
  "identifier": "com.openproxy.tool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": {
      "cwd": "../frontend",
      "script": "npm run dev",
      "wait": false
    },
    "beforeBuildCommand": {
      "cwd": "../frontend",
      "script": "npm run build"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "OpenProxy Panel",
        "width": 372,
        "height": 760,
        "resizable": false,
        "fullscreen": false,
        "center": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "OpenProxy",
    "shortDescription": "OpenProxy 双协议桌面代理",
    "longDescription": "OpenProxy 为 Claude Code、Pi 和 OpenCode 提供 OpenAI 与 Anthropic 双协议桌面代理，支持免费模型接入、工具配置和本地服务管理。",
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false,
        "startMenuFolder": "OpenProxy"
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../config",
      "icons/trayTemplate.png",
      "icons/trayTemplateIdle.png",
      "icons/trayTemplateRunA.png",
      "icons/trayTemplateRunB.png",
      "icons/trayWoodpeckerIdle.png",
      "icons/trayWoodpeckerRunA.png",
      "icons/trayWoodpeckerRunB.png",
      "../src",
      "../node_modules"
    ]
  }
}
